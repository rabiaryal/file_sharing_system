# Django Settings
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=file_sharing_system
DB_USER=file_sharing_user
DB_PASSWORD=file_sharing_password
DB_HOST=db
DB_PORT=5432

# PostgreSQL (Docker)
POSTGRES_DB=file_sharing_system
POSTGRES_USER=file_sharing_user
POSTGRES_PASSWORD=file_sharing_password

# Supabase Configuration
SUPABASE_HOST=your-project.supabase.co
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres
SUPABASE_USER=postgres.xxxxx
SUPABASE_PASSWORD=your_supabase_password
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key
SUPABASE_BUCKET=pdfs

# Google OAuth - Get from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_LOG_DB=myapp
MONGO_LOG_COLLECTION=logs

# Queue tuning (these have defaults — optional)
LOG_QUEUE_MAX=10000
LOG_BATCH_SIZE=50
LOG_FLUSH_INTERVAL=2.0
LOG_TTL_SECONDS=2592000
# here top 6 are required , but below 5 are optional